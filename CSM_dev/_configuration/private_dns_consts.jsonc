{
    "keyvault": {
        "dnsZoneName": "privatelink.vaultcore.azure.net",
        "subResource": "vault"
    },
    "staticwebsite": {
        "dnsZoneName": "privatelink.azurestaticapps.net",
        "subResource": "staticSites"
    },
    "storage": {
        "dnsZoneName": "privatelink.blob.core.windows.net",
        "subResource": "blob"
    },
    "cosmosdb": {
